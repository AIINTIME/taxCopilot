generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String              @id @default(uuid())
  slug        String              @unique
  displayName String
  createdAt   DateTime            @default(now())
  admins      Admin[]
  users       User[]
  roles       Role[]
  documents   Document[]
  proposals   GraphRuleProposal[]
}

model Admin {
  id             String        @id @default(uuid())
  username       String
  passwordHash   String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  users          User[]
  documents      Document[]

  @@unique([username, organizationId])
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  name            String
  bio             String?
  profilePhotoUrl String?
  passwordHash    String
  isActive        Boolean       @default(true)
  adminId         String?
  admin           Admin?        @relation(fields: [adminId], references: [id], onDelete: SetNull)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  authLogs        AuthEventLog[]
  roles           UserRole[]

  @@index([email])
  @@index([adminId])
  @@index([organizationId])
}

model Role {
  id             String           @id @default(uuid())
  name           String
  description    String?
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isSystem        Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  permissions    RolePermission[]
  users          UserRole[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  label       String
  description String?
  category    String
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model AuthEventLog {
  id        String   @id @default(uuid())
  action    String
  status    Int
  success   Boolean
  ipAddress String?
  userAgent String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([action, createdAt])
  @@index([userId])
}

enum TaxActRegime {
  ACT_1961
  ACT_2025
}

enum GateStatus {
  VERIFIED
  FLAGGED
  PARTIAL
}

enum ProvisionStatus {
  ACTIVE
  SUPERSEDED
}

/// Insert-only audit trail for every AI/computation query. Rows are never
/// updated or deleted. userId is intentionally a plain field (not a Prisma
/// relation) so the existing User model does not need to be modified.
model AuditLog {
  id                String     @id @default(uuid())
  userId            String?
  query             String
  retrievedChunkIds String[]
  modelVersion      String
  providerName      String
  response          String
  citations         Json
  gateStatus        GateStatus
  asOfDate          DateTime
  createdAt         DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([asOfDate])
}

enum DocumentStatus {
  PROCESSING
  EMBEDDED
  FAILED
}

enum ProposalStatus {
  PENDING_REVIEW
  AUTO_APPROVED
  APPROVED
  REJECTED
}

/// Tracks every admin-uploaded document through the ingestion pipeline.
model Document {
  id                String            @id @default(uuid())
  filename          String
  contentHash       String            @unique
  s3Path            String
  organizationId    String
  organization      Organization      @relation(fields: [organizationId], references: [id])
  uploadedByAdminId String
  uploadedByAdmin   Admin             @relation(fields: [uploadedByAdminId], references: [id])
  chunksEmbedded    Int               @default(0)
  status            DocumentStatus    @default(PROCESSING)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  proposals         GraphRuleProposal[]

  @@index([organizationId])
  @@index([uploadedByAdminId])
}

/// One row per chunk where the LLM extracted a tax rate rule. Saved regardless
/// of evidence verification outcome — PENDING_REVIEW rows need human review.
model GraphRuleProposal {
  id                 String         @id @default(uuid())
  documentId         String
  document           Document       @relation(fields: [documentId], references: [id])
  sourceChunkId      String
  sourceChunkText    String
  sectionNumber      String?
  assetClass         String?
  rate               String?
  indexation         String?
  conditionText      String?
  effectiveFrom      String?
  selector           String?
  evidenceSpan       String?
  evidenceVerified   Boolean        @default(false)
  status             ProposalStatus @default(PENDING_REVIEW)
  autoApproved       Boolean        @default(false)
  committedToGraphAt DateTime?
  organizationId     String
  organization       Organization   @relation(fields: [organizationId], references: [id])
  createdAt          DateTime       @default(now())

  @@index([documentId])
  @@index([status])
  @@index([organizationId])
}

/// Statutory knowledge-graph provisions (permanent KG namespace), versioned
/// by effective date range and regime so retrieval can filter by as-of date.
model KnowledgeGraphProvision {
  id            String          @id @default(uuid())
  sourceId      String
  regime        TaxActRegime
  tier          Int
  effectiveFrom DateTime
  effectiveTo   DateTime?
  status        ProvisionStatus @default(ACTIVE)
  content       String
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([regime, effectiveFrom, effectiveTo])
  @@index([sourceId])
  @@index([status])
}
