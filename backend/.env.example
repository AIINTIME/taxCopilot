DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
REDIS_URL="redis://localhost:6379/0"
FRONTEND_ORIGIN="http://localhost:5173"
JWT_SECRET_KEY="replace-with-at-least-32-random-bytes"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
REFRESH_COOKIE_NAME="taxai_refresh_token"
COOKIE_SECURE=false
ENVIRONMENT="development"
ANTHROPIC_API_KEY="replace-with-anthropic-api-key"
ANTHROPIC_MODEL="claude-sonnet-5"
FALLBACK_LLM_API_KEY="replace-with-fallback-provider-api-key"
FALLBACK_LLM_MODEL="replace-with-fallback-model-name"
LLM_TIMEOUT_SECONDS=30