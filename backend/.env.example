DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
REDIS_URL="redis://localhost:6379/0"
FRONTEND_ORIGIN="http://localhost:5173"
JWT_SECRET_KEY="replace-with-at-least-32-random-bytes"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
REFRESH_COOKIE_NAME="taxai_refresh_token"
COOKIE_SECURE=false
ENVIRONMENT="development"

# LLM Provider (OpenAI or any OpenAI-compatible endpoint)
PRIMARY_LLM_API_KEY="replace-with-openai-api-key"
PRIMARY_LLM_MODEL="gpt-4o"
PRIMARY_LLM_BASE_URL="https://api.openai.com/v1"

# Embeddings (uses same OpenAI key, different model)
EMBEDDING_MODEL="text-embedding-3-large"
EMBEDDING_DIMENSIONS=1536

# Fallback LLM (optional — leave empty to disable)
FALLBACK_LLM_API_KEY=""
FALLBACK_LLM_MODEL=""
LLM_TIMEOUT_SECONDS=30

# Pinecone Vector DB
PINECONE_API_KEY="replace-with-pinecone-api-key"
PINECONE_INDEX="taxai"

# Neo4j Graph DB
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="replace-with-neo4j-password"
